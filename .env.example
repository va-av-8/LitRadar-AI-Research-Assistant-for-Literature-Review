# LitRadar Environment Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=sk-or-...

# Optional: Langfuse for observability
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional: Semantic Scholar API key (without key: 100 req/min limit)
SEMANTIC_SCHOLAR_API_KEY=

# Model settings (defaults shown)
# Options: google/gemini-2.0-flash-001, openai/gpt-4o-mini, anthropic/claude-3-haiku
LLM_MODEL_DEFAULT=google/gemini-2.0-flash-001
LLM_MODEL_SYNTHESIS=google/gemini-2.0-flash-001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Limits and SLO
MAX_ITERATIONS=2
MAX_PAPERS_PER_SESSION=30
SEARCH_RESULTS_PER_QUERY=10
CRITIC_BATCH_SIZE=10
KB_LOOKUP_TOP_K=10
RETRIEVER_TOP_K_SYNTHESIS=5
CHROMA_DB_PATH=./chroma_db
API_TIMEOUT_SECONDS=10
API_RETRY_COUNT=3
BUDGET_SOFT_LIMIT_USD=0.08
BUDGET_HARD_LIMIT_USD=0.15
INJECTION_RATE_STOP_THRESHOLD=0.30

# Langfuse tracing
LANGFUSE_TRACING=true
LANGFUSE_PROJECT=litradar-poc
